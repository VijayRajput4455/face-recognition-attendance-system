POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=face_recognition
POSTGRES_USER=postgres
POSTGRES_PASSWORD=admin123

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_VHOST=/

RABBITMQ_HEARTBEAT=600
RABBITMQ_BLOCKED_TIMEOUT=300

RABBITMQ_EXCHANGE=face_recognition.direct

RABBITMQ_USE_SSL=false

RABBITMQ_CONNECT_MAX_RETRIES=5
RABBITMQ_CONNECT_BACKOFF_BASE=0.5
RABBITMQ_CONNECT_BACKOFF_MAX=10

RABBITMQ_PUBLISH_MAX_RETRIES=2

INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_GPU_ID=0
INSIGHTFACE_DET_SIZE=640
INSIGHTFACE_DETECTION_THRESHOLD=0.6
INSIGHTFACE_MAX_FACES=1

FACE_MIN_CONFIDENCE=0.70

FACE_MIN_FACE_WIDTH=120
FACE_MIN_FACE_HEIGHT=120

FACE_MIN_BLUR_SCORE=120

FACE_MIN_BRIGHTNESS=60
FACE_MAX_BRIGHTNESS=220

FACE_MAX_YAW=25
FACE_MAX_PITCH=20
FACE_MAX_ROLL=20

MILVUS_URI=http://localhost:19530

MILVUS_COLLECTION=employee_faces

MILVUS_DIMENSION=512

MILVUS_METRIC_TYPE=COSINE

MILVUS_INDEX_TYPE=HNSW

MILVUS_USERNAME=

MILVUS_PASSWORD=

LOG_LEVEL=INFO

LOG_STORAGE_PATH=logs

APP_ENV=development

APP_NAME=face-recognition-system

# DATABASE_URL=postgresql://postgres:admin123@localhost:5432/face_recognition


